root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
tab_width = 4

[*.c]

[Dockerfile]
indent_size = 2
tab_width = 2

[*.{gitconfig,gitattributes,gitignore}]
indent_size = 2
tab_width = 2

[*.json]
indent_size = 2
tab_width = 2

[Makefile]
indent_style = tab

[*.md]

[*.py]

[*.sh]
indent_size = 2
tab_width = 2

[*.toml]
indent_size = 2
tab_width = 2

[*.{yml,yaml}]
indent_size = 2
tab_width = 2
